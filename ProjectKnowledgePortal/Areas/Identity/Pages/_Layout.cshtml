<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - ProjectKnowledgePortal</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/ProjectKnowledgePortal.styles.css" asp-append-version="true" />
</head>
<body>
	<header class="border-bottom box-shadow-sm">
		<nav class="navbar navbar-expand-sm navbar-light bg-white">
			<div class="container-fluid px-3">
				<a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
					<img src="~/images/zeiss-logo.png" asp-append-version="true" alt="ZEISS Logo" class="brand-logo" />
					<span class="fw-semibold text-dark">ProjectKnowledgePortal</span>
				</a>
			</div>
		</nav>
	</header>

	<main role="main" class="container py-4">
		@RenderBody()
	</main>

	<footer class="footer text-muted">
		<div class="container py-2 border-top">
			&copy; 2026 - ProjectKnowledgePortal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
		</div>
	</footer>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
