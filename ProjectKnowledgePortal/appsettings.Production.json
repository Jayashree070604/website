{
  "Database": {
    "Provider": "postgresql"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_RENDER_POSTGRES_HOST;Port=5432;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Storage": {
    "UploadsRootPath": "/data/projectknowledgeportal/uploads"
  },
  "ObjectStorage": {
    "Enabled": true,
    "ServiceUrl": "https://YOUR_S3_COMPATIBLE_ENDPOINT",
    "Region": "us-east-1",
    "BucketName": "YOUR_BUCKET_NAME",
    "AccessKey": "YOUR_ACCESS_KEY",
    "SecretKey": "YOUR_SECRET_KEY",
    "ForcePathStyle": true,
    "KeyPrefix": "pkp"
  },
  "SeedSuperAdmin": {
    "Email": "superadmin@pkm.local",
    "Password": "CHANGE_ME_IN_PRODUCTION",
    "FirstName": "Super",
    "LastName": "Admin"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
