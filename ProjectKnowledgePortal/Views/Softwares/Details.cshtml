@model ProjectKnowledgePortal.ViewModels.Links.LinkDetailsViewModel
@using ProjectKnowledgePortal.Helpers

@{
	ViewData["Title"] = "Software Details";
}

<div class="card shadow-sm">
	<div class="card-header">
		<h5 class="mb-0">Software Details</h5>
	</div>
	<div class="card-body">
		<dl class="row mb-0">
			<dt class="col-sm-3">Title</dt>
			<dd class="col-sm-9">@Model.Title</dd>

			<dt class="col-sm-3">Download URL</dt>
			<dd class="col-sm-9"><a href="@Model.Url" target="_blank" rel="noopener noreferrer">@Model.Url</a></dd>

			<dt class="col-sm-3">Project</dt>
			<dd class="col-sm-9">@Model.ProjectName</dd>

			<dt class="col-sm-3">Category</dt>
			<dd class="col-sm-9">@(Model.CategoryName ?? "-")</dd>

			<dt class="col-sm-3">Description</dt>
			<dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>

			<dt class="col-sm-3">Created (UTC)</dt>
			<dd class="col-sm-9">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</dd>
		</dl>
	</div>
	<div class="card-footer d-flex gap-2">
		<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
		<a class="btn btn-outline-success" asp-action="Download" asp-route-id="@Model.Id" target="_blank">Download</a>
		@if (User.IsInRole(RoleConstants.SuperAdmin) || User.IsInRole(RoleConstants.Admin))
		{
			<a class="btn btn-outline-warning" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
			<a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
		}
	</div>
</div>
