@model ProjectKnowledgePortal.ViewModels.ActivityLogs.ActivityLogDetailsViewModel

@{
	ViewData["Title"] = "Activity Log Details";
}

<div class="card shadow-sm">
	<div class="card-header">
		<h5 class="mb-0">Activity Log Details</h5>
	</div>
	<div class="card-body">
		<dl class="row mb-0">
			<dt class="col-sm-3">Type</dt>
			<dd class="col-sm-9">@Model.ActivityType</dd>

			<dt class="col-sm-3">Description</dt>
			<dd class="col-sm-9">@Model.Description</dd>

			<dt class="col-sm-3">Entity Type</dt>
			<dd class="col-sm-9">@(Model.EntityType ?? "-")</dd>

			<dt class="col-sm-3">Entity Id</dt>
			<dd class="col-sm-9">@(Model.EntityId ?? "-")</dd>

			<dt class="col-sm-3">Project</dt>
			<dd class="col-sm-9">@(Model.ProjectName ?? "-")</dd>

			<dt class="col-sm-3">Performed By (User Id)</dt>
			<dd class="col-sm-9">@(Model.PerformedByUserId ?? "-")</dd>

			<dt class="col-sm-3">IP Address</dt>
			<dd class="col-sm-9">@(Model.IpAddress ?? "-")</dd>

			<dt class="col-sm-3">Created (IST)</dt>
			<dd class="col-sm-9">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</dd>
		</dl>
	</div>
	<div class="card-footer">
		<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
	</div>
</div>
