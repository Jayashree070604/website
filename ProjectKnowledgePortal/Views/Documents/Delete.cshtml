@model ProjectKnowledgePortal.ViewModels.Documents.DocumentDeleteViewModel

@{
	ViewData["Title"] = "Delete Document";
}

<div class="card shadow-sm border-danger">
	<div class="card-header bg-danger text-white">
		<h5 class="mb-0">Delete Document</h5>
	</div>
	<div class="card-body">
		<p class="mb-3">Are you sure you want to permanently delete this document and its physical file?</p>

		<dl class="row mb-0">
			<dt class="col-sm-3">Name</dt>
			<dd class="col-sm-9">@Model.Name</dd>

			<dt class="col-sm-3">Project</dt>
			<dd class="col-sm-9">@Model.ProjectName</dd>

			<dt class="col-sm-3">Type</dt>
			<dd class="col-sm-9">@Model.FileExtension</dd>
		</dl>
	</div>
	<div class="card-footer d-flex gap-2">
		<form asp-action="Delete" method="post" class="d-inline">
			@Html.AntiForgeryToken()
			<input asp-for="Id" type="hidden" />
			<button type="submit" class="btn btn-danger">Delete Permanently</button>
		</form>
		<a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
	</div>
</div>
