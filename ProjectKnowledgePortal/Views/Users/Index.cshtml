@model ProjectKnowledgePortal.ViewModels.Users.UserManagementIndexViewModel

@{
	ViewData["Title"] = "User Management";
}

<div class="card shadow-sm">
	<div class="card-header d-flex justify-content-between align-items-center">
		<h5 class="mb-0">User Management</h5>
		<a class="btn btn-primary btn-sm" asp-action="Create">Create User</a>
	</div>
	<div class="card-body">
		@if (TempData["SuccessMessage"] is string successMessage)
		{
			<div class="alert alert-success">@successMessage</div>
		}
		@if (TempData["ErrorMessage"] is string errorMessage)
		{
			<div class="alert alert-danger">@errorMessage</div>
		}

		<div class="table-responsive">
			<table class="table table-striped align-middle">
				<thead>
					<tr>
						<th>Email</th>
						<th>Role</th>
						<th class="text-end">Actions</th>
					</tr>
				</thead>
				<tbody>
					@if (Model.Users.Count == 0)
					{
						<tr>
							<td colspan="3" class="text-center text-muted py-4">No users found.</td>
						</tr>
					}
					else
					{
						@foreach (var user in Model.Users)
						{
							<tr>
								<td>@user.Email</td>
								<td>
									<form asp-action="AssignRole" method="post" class="d-flex gap-2">
										@Html.AntiForgeryToken()
										<input type="hidden" name="userId" value="@user.Id" />
										<select name="role" class="form-select form-select-sm">
											@foreach (var role in Model.AvailableRoles)
											{
												<option value="@role" selected="@(user.Roles.Contains(role))">@role</option>
											}
										</select>
										<button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
									</form>
								</td>
								<td class="text-end">
								<form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
										@Html.AntiForgeryToken()
										<input type="hidden" name="userId" value="@user.Id" />
									<button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
									</form>
									<a class="btn btn-sm btn-outline-secondary" asp-action="ResetPassword" asp-route-userId="@user.Id">Reset Password</a>
								</td>
							</tr>
						}
					}
				</tbody>
			</table>
		</div>
	</div>
</div>
