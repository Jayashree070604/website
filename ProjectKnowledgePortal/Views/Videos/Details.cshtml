@model ProjectKnowledgePortal.ViewModels.Videos.VideoDetailsViewModel
@using ProjectKnowledgePortal.Helpers

@{
	ViewData["Title"] = "Video Details";
}

<div class="card shadow-sm">
	<div class="card-header">
		<h5 class="mb-0">Video Details</h5>
	</div>
	<div class="card-body">
		<div class="ratio ratio-16x9 mb-3">
			<video controls preload="metadata" class="w-100">
				<source src="@Url.Action("Stream", "Videos", new { id = Model.Id })" type="video/mp4" />
				Your browser does not support HTML5 video playback.
			</video>
		</div>

		<dl class="row mb-0">
			<dt class="col-sm-3">Name</dt>
			<dd class="col-sm-9">@Model.Name</dd>

			<dt class="col-sm-3">Project</dt>
			<dd class="col-sm-9">@Model.ProjectName</dd>

			<dt class="col-sm-3">Category</dt>
			<dd class="col-sm-9">@(Model.CategoryName ?? "-")</dd>

			<dt class="col-sm-3">Content Type</dt>
			<dd class="col-sm-9">@Model.ContentType</dd>

			<dt class="col-sm-3">File Size</dt>
			<dd class="col-sm-9">@(Math.Round(Model.FileSizeBytes / (1024.0 * 1024.0), 2)) MB</dd>

			<dt class="col-sm-3">Uploaded (UTC)</dt>
			<dd class="col-sm-9">@Model.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm")</dd>

			<dt class="col-sm-3">Uploaded By (User Id)</dt>
			<dd class="col-sm-9">@Model.UploadedByUserId</dd>
		</dl>
	</div>
	<div class="card-footer d-flex gap-2">
		<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
		<a class="btn btn-outline-success" asp-action="Download" asp-route-id="@Model.Id">Download</a>
		@if (User.IsInRole(RoleConstants.SuperAdmin) || User.IsInRole(RoleConstants.Admin))
		{
			<a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
		}
	</div>
</div>
