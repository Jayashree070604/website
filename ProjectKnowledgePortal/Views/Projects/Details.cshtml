@model ProjectKnowledgePortal.ViewModels.Projects.ProjectDetailsViewModel
@using ProjectKnowledgePortal.Helpers

@{
	ViewData["Title"] = "Project Details";
}

<div class="card shadow-sm">
	<div class="card-header">
		<h5 class="mb-0">Project Details</h5>
	</div>
	<div class="card-body">
		<dl class="row mb-0">
			<dt class="col-sm-3">Name</dt>
			<dd class="col-sm-9">@Model.Name</dd>

			<dt class="col-sm-3">Code</dt>
			<dd class="col-sm-9">@Model.Code</dd>

			<dt class="col-sm-3">Description</dt>
			<dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>

			<dt class="col-sm-3">Team Members</dt>
			<dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.TeamMembers) ? "-" : Model.TeamMembers)</dd>
		</dl>
	</div>
	<div class="card-footer d-flex gap-2">
		<a class="btn btn-outline-secondary" asp-action="Index">Back</a>
		@if (User.IsInRole(RoleConstants.SuperAdmin) || User.IsInRole(RoleConstants.Admin))
		{
			<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
		}
		@if (User.IsInRole(RoleConstants.SuperAdmin))
		{
			<a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
		}
	</div>
</div>
